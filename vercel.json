{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install && npm install --prefix api",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "includeFiles": "api/**"
    },
    "api/app.mjs": {
      "maxDuration": 30,
      "includeFiles": "api/**"
    }
  }
}
